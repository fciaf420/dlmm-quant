# ---- required ----

# Solana RPC endpoint (Helius, Flux, Triton, etc.)
RPC_URL=https://your-rpc-provider.com/?key=YOUR_KEY

# Bot wallet: EITHER a path to a JSON byte-array keypair file...
KEYPAIR_PATH=/absolute/path/to/keypair.json
# ...OR a base58-encoded private key (Phantom export format). KEYPAIR_PATH wins if both set.
# PRIVATE_KEY=your_base58_private_key

# Jupiter API key (free at https://portal.jup.ag) — used for token data + swaps
JUP_API_KEY=jup_xxxxxxxxxxxx


# ---- tunables (all optional; shown with their defaults) ----
# Every value below falls back to the default if unset or blank, so you only need to
# list the ones you want to change. A non-numeric value logs a warning and uses the default.

# Quote token every pool must be paired against, as token_y.
# The deploy path swaps QUOTE_MINT -> token_x and treats the Y side as this mint's
# lamports, so pools quoted in anything else (SOL-HYPE, which is X=SOL, or *-USDC pools)
# are filtered out of the scan and rejected by deploy. Changing this without reworking
# the decimal handling in deploy.cjs will produce wrong deposit sizes.
# QUOTE_MINT=So11111111111111111111111111111111111111112

# --- loop timing ---
# TICK_MS=120000          # manage open positions every tick (2 min)
# SCAN_EVERY=7            # scan for new entries every Nth tick (7 x 2min = ~14 min)

# --- candidate universe ---
# MIN_TVL=60000           # skip pools below this TVL
# MIN_VOL_24H=150000      # skip pools below this 24h volume
# SCAN_TOP_N=8            # candidates examined per scan, ranked by fee rate
# COOLDOWN_H=2            # hours before re-entering a pool after exiting it

# --- position sizing, in SOL ---
# Each open position also locks rent (~0.057 SOL at 70 bins, more when wider) plus
# FEE_BUFFER_SOL of headroom. Budget roughly size + 0.15 per concurrent position.
# MAX_POSITIONS=2         # concurrent positions; also enforced in deploy.cjs
# SIZE_IGNITION=0.3       # IGNITION entry
# SIZE_IGNITION_HI=0.4    # IGNITION when edge >= 2
# SIZE_BASING=0.3
# SIZE_CARRY=0.4
# SIZE_SQUEEZE=0.3

# --- deploy mechanics ---
# MAX_BINS=140            # bins per position. AddLiquidityByStrategy2 runs out of heap
#                         # above ~145 (351 panics, 145 works); the true ceiling is
#                         # unmeasured. Raising this risks "memory allocation failed".
#                         # Wider ranges on fine bin-step pools get clamped to fit.
# FEE_BUFFER_SOL=0.08     # headroom required over position size + rent before deploying
# SLIPPAGE_BPS=300        # Jupiter swap slippage (300 = 3%)
