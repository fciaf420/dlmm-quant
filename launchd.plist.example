<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>com.dlmm.quant-trader</string>
  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/bin/node</string>
    <string>/ABSOLUTE/PATH/TO/dlmm-quant/trader_daemon.cjs</string>
  </array>
  <key>WorkingDirectory</key><string>/ABSOLUTE/PATH/TO/dlmm-quant</string>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>StandardOutPath</key><string>/ABSOLUTE/PATH/TO/dlmm-quant/daemon.out</string>
  <key>StandardErrorPath</key><string>/ABSOLUTE/PATH/TO/dlmm-quant/daemon.err</string>
</dict>
</plist>
